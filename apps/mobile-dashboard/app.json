{
  "expo": {
    "name": "AgriKöprü",
    "slug": "mobile-dashboard",
    "version": "1.0.0",
    "scheme": "agrikopru",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.mobile-dashboard",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "ÇKS belgesi yüklemek için galeri erişimi gereklidir.",
        "NSCameraUsageDescription": "ÇKS belgesi fotoğraflamak için kamera erişimi gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.mobiledashboard"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-image-picker"
    ]
  }
}
